{
  "ApplicationSettings": {
    "ApiKey": "PLACEHOLDER_SET_BY_CI",
    "HistoryTimeThresholdMinutes": 360,
    "StationaryDirectionNullThresholdHours": 6
  },
  "ConnectionStrings": {
    "TelemetryDatabase": "Data Source=telemetry.db"
  },
  "Mailtrap": {
    "ApiToken": "PLACEHOLDER_SET_BY_CI",
    "FromAddress": "PLACEHOLDER_SET_BY_CI"
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/beta-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 30,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  }
}
